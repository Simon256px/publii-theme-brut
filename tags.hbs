{{> head}}

<main class="main" id="top">
    <section class="hero hero--compact">
        {{> sparkles}}
        <div class="hero__kicker-row">
            <span class="mono-label">{{@config.custom.labelTags}} — {{tagsNumber}}</span>
        </div>
        <h1 class="hero__title">{{@config.custom.labelTags}}</h1>
    </section>

    <ul class="tag-cloud">
        {{#each tags}}
            <li>
                <a href="{{url}}" class="tag-cloud__item">
                    <span class="tag-cloud__name">{{name}}</span>
                    <span class="tag-cloud__count mono-label">{{postsNumber}}</span>
                </a>
            </li>
        {{/each}}
    </ul>
</main>

{{> footer}}
