    "customElements": [
        {
            "label": "Marker (black highlight)",
            "cssClasses": "mrk",
            "selector": "p"
        },
        {
            "label": "Mono label",
            "cssClasses": "label-mono",
            "selector": "p"
        },
        {
            "label": "Box — pastel 1",
            "cssClasses": "msg msg--p1",
            "selector": "p"
        },
        {
            "label": "Box — pastel 2",
            "cssClasses": "msg msg--p2",
            "selector": "p"
        },
        {
            "label": "Box — pastel 3",
