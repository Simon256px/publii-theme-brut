    "files": {
        "ignoreAssets": [".DS_Store"],
        "assetsPath": "assets",
        "partialsPath": "partials",
        "responsiveImages": {
            "contentImages": {
                "sizes": "(max-width: 56em) 100vw, 840px",
                "dimensions": {
                    "xs": {
                        "width": 480,
                        "height": "auto"
                    },
                    "sm": {
                        "width": 840,
                        "height": "auto"
                    },
                    "md": {
                        "width": 1280,
                        "height": "auto"
                    }
                }
            },
            "featuredImages": {
                "sizes": {
                    "post": "(max-width: 84em) 100vw, 1280px",
                    "listing": "(max-width: 48em) 100vw, 640px"
                },
                "dimensions": {
                    "xs": {
                        "width": 480,
                        "height": "auto",
                        "group": "post,listing"
                    },
                    "sm": {
                        "width": 840,
                        "height": "auto",
                        "group": "post,listing"
                    },
                    "md": {
                        "width": 1280,
                        "height": "auto",
                        "group": "post"
                    },
                    "lg": {
                        "width": 1600,
                        "height": "auto",
                        "group": "post"
                    }
                }
            },
            "optionImages": {
                "sizes": "(max-width: 84em) 100vw, 1280px",
